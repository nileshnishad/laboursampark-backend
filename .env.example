# ==========================================
# Environment Variables Example
# ==========================================
# Copy this file to .env and fill in the actual values
# DO NOT commit .env to version control

# ==========================================
# Server Configuration
# ==========================================
NODE_ENV=development
PORT=5000

# ==========================================
# Database Configuration
# ==========================================
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/DATABASE?retryWrites=true&w=majority

# ==========================================
# Authentication
# ==========================================
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d

# ==========================================
# PayU Payment Gateway
# ==========================================
PAYU_KEY=Wcne5u
PAYU_SALT=0LDrTMzqXMnMq8CbjUV9lkV89fXSIpKF
# Use https://test.payu.in for sandbox and https://secure.payu.in for production
PAYU_BASE_URL=https://test.payu.in
# Public backend base URL where PayU can send callbacks
PAYU_CALLBACK_BASE_URL=http://localhost:9000
# Comma-separated allowlist for frontend redirect URLs
PAYU_ALLOWED_REDIRECT_BASES=http://localhost:3000

# ==========================================
# For Vercel Deployment
# ==========================================
# Set these variables in Vercel Dashboard:
# Settings > Environment Variables
# 
# MONGO_URI=mongodb+srv://...
# JWT_SECRET=your_secure_secret_here
# JWT_EXPIRES_IN=7d
# NODE_ENV=production
